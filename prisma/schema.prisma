// データベースへの接続設定
datasource db {
  provider = "postgresql"
}

// TypeScript用のプログラム（Client）を自動生成する設定
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../generated/prisma/client" // 出力先をカスタムディレクトリに指定
}

// 【変更】タスクを管理するためのデータモデル
model Todo {
  id          Int       @id @default(autoincrement()) // 自動で増える識別番号
  title       String    // タスクの名前
  isCompleted Boolean   @default(false)               // 完了状態（初期値は未完了）
  dueDate     DateTime? // 期日（未設定も可）
  
  // 【変更】文字列から「分類モデル」との結びつきに変更
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId  Int?      // 所属する分類の識別番号

  createdAt   DateTime  @default(now())               // 作成日時
}

// 【新設】分類（カテゴリ）をマスター管理するためのデータモデル
model Category {
  id       Int     @id @default(autoincrement()) // 自動で増える分類の識別番号
  name     String  @unique                       // 分類名（重複を許さない）
  
  // 【ポイント】分類を「削除」する代わりに「非表示（false）」にするためのフラグ
  isActive Boolean @default(true)                // 有効状態（初期値は有効）
  
  todos    Todo[]  // この分類がセットされているタスクたちのリンク（Prismaの仕組み上必要）
}
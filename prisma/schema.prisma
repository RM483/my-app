// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 【新設】タスクを管理するためのデータモデル
model Todo {
  id          Int      @id @default(autoincrement()) // 自動で1ずつ増える識別番号
  title       String                                 // タスクの名前（タイトル）
  isCompleted Boolean  @default(false)               // 完了フラグ（初期値は未完了のfalse）
  createdAt   DateTime @default(now())               // タスクが作られた日時（自動記録）
}
// データベースへの接続設定
datasource db {
  provider = "postgresql"
}

// TypeScript用のプログラム（Client）を自動生成する設定
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  output          = "../generated/prisma/client" // 出力先をカスタムディレクトリに指定
}

// タスクを管理するためのデータモデル
model Todo {
  id          Int       @id @default(autoincrement()) // 自動で増える識別番号
  title       String    // タスクの名前
  isCompleted Boolean   @default(false)               // 完了状態（初期値は未完了）
  dueDate     DateTime? // 期日（未設定も可）
  
  // 【新設】重要度を保存する項目（初期値は"中"）
  priority    String    @default("中")

  // 一日スケジュール上の配置時間（未配置の場合は両方null）
  scheduledStart DateTime?
  scheduledEnd   DateTime?

  // 自動配置専用の設定（手動で配置した実時間とは別に保持）
  estimatedMinutes Int?
  isSplittable     Boolean @default(false)
  splitMinutes     Int?

  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId  Int?      // 所属する分類の識別番号
  schedules   TodoSchedule[]

  createdAt   DateTime  @default(now())               // 作成日時
}

// 分類（カテゴリ）をマスター管理するためのデータモデル
model Category {
  id       Int     @id @default(autoincrement()) // 自動で増える分類の識別番号
  name     String  // 分類名
  isActive Boolean @default(true)                // 有効状態（初期値は有効）
  todos    Todo[]  // この分類がセットされているタスクたちのリンク
}
// タスクを日付ごとに複数配置するためのデータモデル
model TodoSchedule {
  id             Int      @id @default(autoincrement())
  todoId         Int
  scheduledStart DateTime
  scheduledEnd   DateTime
  createdAt      DateTime @default(now())

  todo Todo @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@unique([todoId, scheduledStart, scheduledEnd])
  @@index([scheduledStart])
}

// ユーザー共通設定。現在は userKey="default" の1件だけを使用する
model UserSetting {
  id      Int    @id @default(autoincrement())
  userKey String @unique

  autoPlacementDays AutoPlacementDay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 曜日ごとの自動配置許可設定（weekday: 1=月曜日 ... 7=日曜日）
model AutoPlacementDay {
  id            Int     @id @default(autoincrement())
  userSettingId Int
  weekday       Int
  isEnabled     Boolean @default(false)

  userSetting UserSetting             @relation(fields: [userSettingId], references: [id], onDelete: Cascade)
  timeRanges  AutoPlacementTimeRange[]

  @@unique([userSettingId, weekday])
  @@index([userSettingId])
}

// 1曜日に複数設定できる自動配置許可時間帯
model AutoPlacementTimeRange {
  id          Int @id @default(autoincrement())
  dayId       Int
  startMinute Int
  endMinute   Int

  day AutoPlacementDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

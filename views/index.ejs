<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>シンプルタスク管理アプリ</title>
</head>
<body>
  <h1>タスク一覧</h1>
  <ul>
    <% todos.forEach(todo => { %>
      <li style="margin-bottom: 10px; display: flex; align-items: center;">
        
        <form action="/todos/<%= todo.id %>/toggle" method="POST" style="display: inline;">
          <% if (todo.isCompleted) { %>
            <span style="color: gray; text-decoration: line-through; margin-right: 10px;">
              <strong><%= todo.title %></strong> (完了)
              <% if (todo.dueDate) { %>
                <span style="font-size: 0.9em; color: darkgray; margin-left: 10px;">
                  ⏰ 期日: <%= new Date(todo.dueDate).toLocaleDateString("ja-JP") %>
                </span>
              <% } %>
            </span>
            <button type="submit">未完了に戻す</button>
          <% } else { %>
            <span style="margin-right: 10px;">
              <strong><%= todo.title %></strong> <span style="color: red;">(未完了)</span>
              <% if (todo.dueDate) { %>
                <span style="font-size: 0.9em; color: #555; margin-left: 10px;">
                  ⏰ 期日: <%= new Date(todo.dueDate).toLocaleDateString("ja-JP") %>
                </span>
              <% } %>
            </span>
            <button type="submit">完了する</button>
          <% } %>
        </form>

        <form action="/todos/<%= todo.id %>/delete" method="POST" style="display: inline; margin-left: 10px;">
          <button type="submit" style="color: white; background-color: red; border: none; padding: 3px 8px; cursor: pointer;">削除</button>
        </form>

      </li>
    <% }) %>
  </ul>

  <h2>タスクを追加する</h2>
  <form action="/todos" method="POST">
    <input type="text" name="title" placeholder="新しいタスクを入力してください" required>
    
    <label style="margin-left: 10px; margin-right: 10px;">
      期日: <input type="date" name="dueDate">
    </label>

    <button type="submit">追加</button>
  </form>

  <p style="margin-top: 20px;"><a href="/">最新の状態に更新</a></p>
</body>
</html>
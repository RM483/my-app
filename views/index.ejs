<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>シンプルタスク管理アプリ</title>
</head>
<body>
  <h1>タスク一覧</h1>
  <ul>
    <% todos.forEach(todo => { %>
      <li>
        <strong><%= todo.title %></strong>
        <% if (todo.isCompleted) { %>
          <span style="color: gray; text-decoration: line-through;">(完了)</span>
        <% } else { %>
          <span style="color: red;">(未完了)</span>
        <% } %>
      </li>
    <% }) %>
  </ul>

  <h2>タスクを追加する</h2>
  <form action="/todos" method="POST">
    <input type="text" name="title" placeholder="新しいタスクを入力してください" required>
    <button type="submit">追加</button>
  </form>

  <p style="margin-top: 20px;"><a href="/">最新の状態に更新</a></p>
</body>
</html>
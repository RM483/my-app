<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>ユーザー一覧（年齢対応版）</title>
</head>
<body>
  <h1>ユーザー一覧</h1>
  <ul>
    <% users.forEach(user => { %>
      <!-- 名前だけでなく、年齢があれば表示、なければ「未設定」と出すぞ -->
      <li>
        <%= user.name %> 
        (<%= user.age !== null ? user.age + '歳' : '年齢未設定' %>)
      </li>
    <% }) %>
  </ul>

  <h2>ユーザーを追加する</h2>
  <form action="/users" method="post">
    <div>
      <label>名前：</label>
      <input type="text" name="name" placeholder="名前を入力" required>
    </div>
    <div style="margin-top: 10px;">
      <label>年齢：</label>
      <!-- 年齢を入れるための数字専用の入力欄じゃ -->
      <input type="number" name="age" placeholder="年齢を入力">
    </div>
    <button type="submit" style="margin-top: 10px;">追加する</button>
  </form>

  <p><a href="/">最新の状態に更新</a></p>
</body>
</html>


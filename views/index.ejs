<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>進化系タスク管理アプリ</title>
  
  <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
  
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>
  <% const safeFormValues = typeof formValues !== 'undefined' ? formValues : {}; %>
  <% const safeErrorMessage = typeof errorMessage !== 'undefined' ? errorMessage : null; %>
  <% const safeDuplicateTodoId = typeof duplicateTodoId !== 'undefined' ? duplicateTodoId : null; %>
  <% const safeErrorType = typeof error !== 'undefined' ? error : null; %>
  <% const safeAutoPlacementEditTodoId = typeof autoPlacementEditTodoId !== 'undefined' ? autoPlacementEditTodoId : null; %>
  <%
    const formatEstimatedHours = (minutes) => {
      if (!minutes) return '';
      const hours = minutes / 60;
      return Number.isInteger(hours)
        ? String(hours)
        : hours.toFixed(2).replace(/0+$/, '').replace(/\.$/, '');
    };
  %>
  <header class="app-page-header">
    <h1>タスク管理システム</h1>
    <a href="/settings" class="user-settings-link">⚙ ユーザー設定</a>
  </header>

  <div class="view-switcher">
    <button type="button" id="todayScheduleViewBtn" class="switch-btn active" onclick="switchView('today')">🕒 今日のスケジュール</button>
    <button type="button" id="listViewBtn" class="switch-btn" onclick="switchView('list')">📋 リスト表示</button>
    <button type="button" id="calendarViewBtn" class="switch-btn" onclick="switchView('calendar')">📅 カレンダー表示</button>
  </div>

  <div id="todayScheduleViewArea">
    <section class="today-schedule-card" aria-labelledby="todayScheduleTitle">
      <div class="today-schedule-header">
        <div>
          <h2 id="todayScheduleTitle">今日のスケジュール</h2>
          <p id="todayScheduleSubtitle">今日の予定を読み込んでいます</p>
        </div>
        <span class="today-schedule-guide">配置済みタスクはドラッグ・上下リサイズできます</span>
      </div>
      <div id="todayScheduleTimeline" class="schedule-timeline today-schedule-timeline"></div>
    </section>
  </div>

  <div id="listViewArea" class="hidden">
    <div class="search-container">
      <input type="text" id="taskSearchInput" class="search-input" placeholder="🔍 タスク名でキーワード検索... (入力すると一瞬で絞り込みます)" oninput="applyFilters()">
    </div>
    
    <% if (categories.length > 0 || todos.some(t => !t.categoryId)) { %>
      <div class="category-filter-container">
        <button type="button" class="filter-btn master-btn" id="masterFilterBtn" onclick="toggleMasterFilter()">
          <span class="icon">📄</span> すべて表示
        </button>
        <% categories.forEach(cat => { %>
          <button type="button" class="filter-btn category-btn" data-category-id="<%= cat.id %>" onclick="toggleCategoryFilter(this)">
            <span class="check-mark">✓</span> <%= cat.name %>
          </button>
        <% }) %>
        <button type="button" class="filter-btn category-btn" data-category-id="none" onclick="toggleCategoryFilter(this)">
          <span class="check-mark">✓</span> [分類なし]
        </button>
      </div>
    <% } %>

    <% if (safeErrorType === 'listDuplicate' || safeErrorType === 'listEmptyTitle') { %>
      <div class="client-error-msg" style="margin-bottom: 12px;">
        <span>⚠️</span>
        <span><%= safeErrorMessage || '入力内容に問題があります。' %></span>
      </div>
    <% } %>

    <%
      const todoColumns = categories
        .map(category => ({
          id: String(category.id),
          name: category.name,
          todos: todos.filter(todo => String(todo.categoryId) === String(category.id)),
        }))
        .filter(column => column.todos.length > 0);
      const uncategorizedTodos = todos.filter(todo => !todo.categoryId);
      if (uncategorizedTodos.length > 0) {
        todoColumns.push({
          id: 'none',
          name: '分類なし',
          todos: uncategorizedTodos,
        });
      }
    %>
    <div class="todo-container">
      <% if (todos.length === 0) { %>
        <p style="color: gray; text-align: center;">タスクはまだありませんぞよ。</p>
      <% } %>
      <p id="todoFilterEmptyState" class="todo-filter-empty hidden">検索・絞り込み条件に一致するタスクはありません。</p>
      <div class="todo-category-board">
        <% todoColumns.forEach(column => { %>
          <section class="todo-category-column" data-category-column="<%= column.id %>">
            <div class="todo-category-column-header">
              <h3><%= column.name %></h3>
              <span class="todo-category-count"><span class="todo-category-visible-count"><%= column.todos.length %></span>件</span>
            </div>
            <ul class="todo-category-task-list">
              <% column.todos.forEach(todo => { %>
          <% 
            let alertClass = "";
            let dateTextClass = "";
            let prefixText = "";
            let dateString = "";

            if (todo.dueDate) {
              const d = new Date(todo.dueDate);
              dateString = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
              
              const today = new Date('2026-07-08');
              today.setHours(0,0,0,0);
              const taskDate = new Date(todo.dueDate);
              taskDate.setHours(0,0,0,0);

              if (!todo.isCompleted) {
                if (taskDate.getTime() === today.getTime()) {
                  alertClass = "alert-today";
                  dateTextClass = "date-text-today";
                  prefixText = "📅 今日";
                } else if (taskDate.getTime() < today.getTime()) {
                  alertClass = "alert-overdue";
                  dateTextClass = "date-text-overdue";
                  prefixText = "🚨 期限切れ";
                }
              }
            }
          %>
          <li class="todo-item <%= alertClass %>" data-cat="<%= todo.categoryId ? todo.categoryId : 'none' %>" data-title="<%= todo.title.toLowerCase() %>">
            <form action="/todos/<%= todo.id %>/toggle" method="POST" style="display: flex; align-items: center;">
              <button type="submit" class="toggle-check-btn <%= todo.isCompleted ? 'completed' : '' %>">✓</button>
            </form>

            <form action="/todos/<%= todo.id %>/update" method="POST" style="display: flex; align-items: center;">
              <select name="priority" class="inline-select <%= todo.isCompleted ? 'completed' : '' %>" onchange="this.form.submit()">
                <option value="高" <%= todo.priority === '高' ? 'selected' : '' %>>🚨 高</option>
                <option value="中" <%= todo.priority === '中' ? 'selected' : '' %>>🟡 中</option>
                <option value="低" <%= todo.priority === '低' ? 'selected' : '' %>>🟢 低</option>
              </select>
            </form>

            <div class="todo-category-control">
              <form action="/todos/<%= todo.id %>/category" method="POST" id="catForm-<%= todo.id %>" style="display: flex; align-items: center;">
                <select name="categoryId" class="inline-select todo-category-select <%= todo.isCompleted ? 'completed' : '' %>" title="<%= todo.category ? todo.category.name : '分類なし' %>" onchange="handleInlineCategoryChange(this, '<%= todo.id %>')">
                  <option value="指定なし" <%= !todo.categoryId ? 'selected' : '' %>>[分類なし ▾]</option>
                  <% categories.forEach(cat => { %>
                    <option value="<%= cat.id %>" <%= todo.categoryId === cat.id ? 'selected' : '' %>>[<%= cat.name %> ▾]</option>
                  <% }) %>
                  <option value="__INLINE_NEW__">➕ （新しい分類を追加）</option>
                </select>
              </form>
              <form action="/todos/<%= todo.id %>/category/create" method="POST" id="newCatForm-<%= todo.id %>" class="hidden" style="display: flex; align-items: center;">
                <input type="text" name="newCategoryName" class="inline-cat-input" placeholder="分類名を入力..." onblur="cancelInlineCategory('<%= todo.id %>')">
              </form>
            </div>

            <form action="/todos/<%= todo.id %>/update" method="POST" class="todo-title-form" style="flex-grow: 1; display: flex; align-items: center;">
              <input type="text" name="title" class="inline-input-title <%= todo.isCompleted ? 'completed' : '' %>" value="<%= safeFormValues && safeFormValues['todo-' + todo.id + '-title'] !== undefined ? safeFormValues['todo-' + todo.id + '-title'] : todo.title %>" onchange="this.form.submit()" <%= todo.isCompleted ? 'disabled' : '' %>>
            </form>

            <form action="/todos/<%= todo.id %>/update" method="POST" style="display: flex; align-items: center; gap: 4px;">
              <% if (prefixText) { %>
                <span class="<%= dateTextClass %>" style="font-size: 0.8em; white-space: nowrap;"><%= prefixText %></span>
              <% } %>
              <input type="date" name="dueDate" class="inline-date <%= todo.isCompleted ? 'completed' : '' %>" value="<%= safeFormValues && safeFormValues['todo-' + todo.id + '-dueDate'] !== undefined ? safeFormValues['todo-' + todo.id + '-dueDate'] : dateString %>" onchange="this.form.submit()">
            </form>

            <button
              type="button"
              class="auto-placement-summary"
              aria-expanded="<%= safeAutoPlacementEditTodoId === todo.id ? 'true' : 'false' %>"
              aria-controls="autoPlacementEditor-<%= todo.id %>"
              title="自動配置用の詳細設定を編集"
              onclick="toggleAutoPlacementEditor('<%= todo.id %>')"
            >詳細設定</button>

            <form action="/todos/<%= todo.id %>/delete" method="POST" style="display: flex; align-items: center; margin-left: 4px;">
              <button type="submit" style="color: white; background-color: #e53e3e; border: none; padding: 4px 8px; border-radius: 4px; cursor: pointer; font-size: 0.85em;">削除</button>
            </form>

            <div id="autoPlacementEditor-<%= todo.id %>" class="auto-placement-editor <%= safeAutoPlacementEditTodoId === todo.id ? '' : 'hidden' %>">
              <div id="autoPlacementError-<%= todo.id %>" class="client-error-msg auto-placement-inline-error <%= safeAutoPlacementEditTodoId === todo.id && (safeErrorType === 'listInvalidAutoPlacement' || safeErrorType === 'listSplitExceedsDailyLimit' || safeErrorType === 'listSplitExceedsEstimate') ? '' : 'hidden' %>">
                <span>⚠️</span>
                <span><%= safeAutoPlacementEditTodoId === todo.id ? (safeErrorMessage || '自動配置用設定を確認してください。') : '' %></span>
              </div>
              <form action="/todos/<%= todo.id %>/auto-placement" method="POST" class="auto-placement-editor-form" data-saved-estimated-hours="<%= formatEstimatedHours(todo.estimatedMinutes) %>" data-saved-split-hours="<%= formatEstimatedHours(todo.splitMinutes) %>" data-saved-daily-limit-hours="<%= formatEstimatedHours(todo.dailyLimitMinutes) %>" data-error-target="autoPlacementError-<%= todo.id %>">
                <label>
                  <span>見積時間</span>
                  <span class="duration-input">
                    <input type="number" name="estimatedHours" min="0.25" step="0.25" placeholder="未設定" value="<%= safeFormValues['todo-' + todo.id + '-estimatedHours'] !== undefined ? safeFormValues['todo-' + todo.id + '-estimatedHours'] : formatEstimatedHours(todo.estimatedMinutes) %>">
                    <span>時間</span>
                  </span>
                </label>
                <label>
                  <span>分割</span>
                  <select name="isSplittable" id="todoSplittable-<%= todo.id %>" onchange="updateSplitEstimateVisibility('todoSplittable-<%= todo.id %>', 'todoSplitHoursGroup-<%= todo.id %>', 'todoSplitHours-<%= todo.id %>', 'todoDailyLimitHoursGroup-<%= todo.id %>', 'todoDailyLimitHours-<%= todo.id %>')">
                    <% const inlineSplittable = safeFormValues['todo-' + todo.id + '-isSplittable'] !== undefined ? safeFormValues['todo-' + todo.id + '-isSplittable'] === 'true' : todo.isSplittable; %>
                    <option value="false" <%= !inlineSplittable ? 'selected' : '' %>>分割できない</option>
                    <option value="true" <%= inlineSplittable ? 'selected' : '' %>>分割できる</option>
                  </select>
                </label>
                <label id="todoSplitHoursGroup-<%= todo.id %>" class="<%= inlineSplittable ? '' : 'hidden' %>">
                  <span>1回あたり</span>
                  <span class="duration-input">
                    <input type="number" name="splitHours" id="todoSplitHours-<%= todo.id %>" min="0.25" step="0.25" placeholder="例：1" value="<%= safeFormValues['todo-' + todo.id + '-splitHours'] !== undefined ? safeFormValues['todo-' + todo.id + '-splitHours'] : formatEstimatedHours(todo.splitMinutes) %>" <%= inlineSplittable ? 'required' : 'disabled' %>>
                    <span>時間</span>
                  </span>
                </label>
                <label id="todoDailyLimitHoursGroup-<%= todo.id %>" class="<%= inlineSplittable ? '' : 'hidden' %>">
                  <span>1日の実施時間上限</span>
                  <span class="duration-input">
                    <input type="number" name="dailyLimitHours" id="todoDailyLimitHours-<%= todo.id %>" min="0.25" step="0.25" placeholder="例：2" value="<%= safeFormValues['todo-' + todo.id + '-dailyLimitHours'] !== undefined ? safeFormValues['todo-' + todo.id + '-dailyLimitHours'] : (todo.dailyLimitMinutes ? formatEstimatedHours(todo.dailyLimitMinutes) : (inlineSplittable ? '2' : '')) %>" <%= inlineSplittable ? 'required' : 'disabled' %>>
                    <span>時間</span>
                  </span>
                </label>
                <div class="auto-placement-editor-actions">
                  <button type="submit" class="auto-placement-save-btn">保存</button>
                  <button type="button" class="auto-placement-cancel-btn" onclick="cancelAutoPlacementEditor('<%= todo.id %>')">キャンセル</button>
                  <button type="button" class="auto-placement-reset-btn" onclick="resetAutoPlacementEditor('<%= todo.id %>')">リセット</button>
                </div>
              </form>
            </div>
          </li>
              <% }) %>
            </ul>
          </section>
        <% }) %>
      </div>
    </div>
  </div>

  <div id="calendarViewArea" class="hidden">
    <div class="calendar-container">
      <div id="calendar"></div>
    </div>

    <section class="placement-inspector-card" aria-labelledby="placementInspectorTitle">
      <div class="placement-inspector-heading">
        <div>
          <h2 id="placementInspectorTitle">タスクの配置日を確認</h2>
          <p>配置済みタスクを選択すると、月間カレンダーに同じ色のマーカーを表示します。</p>
        </div>
      </div>
      <div class="placement-inspector-search-row">
        <label for="placementTaskSearch">タスク名で検索</label>
        <input type="search" id="placementTaskSearch" placeholder="配置済みタスクを検索">
      </div>
      <div id="placementCategoryFilters" class="placement-category-filters"></div>
      <div class="placement-selection-header">
        <span>選択中：<strong id="placementSelectedCount">0件</strong></span>
        <button type="button" id="clearPlacementSelection" class="placement-clear-btn">選択をすべて解除</button>
      </div>
      <div id="placementSelectedChips" class="placement-selected-chips"></div>
      <div id="placementTaskChoices" class="placement-task-choices"></div>
      <p id="placementTaskEmpty" class="placement-task-empty hidden">条件に一致する配置済みタスクはありません。</p>
    </section>

    <div id="dayScheduleOverlay" class="day-schedule-overlay hidden" aria-hidden="true">
      <div class="day-schedule-panel" role="dialog" aria-modal="true">
        <button type="button" id="closeDayScheduleBtn" class="day-schedule-close" aria-label="閉じる">×</button>
        <div class="day-schedule-body">
          <div id="scheduleTaskSidebar" class="day-schedule-sidebar">
            <div class="day-schedule-sidebar-date">
              <h3 id="scheduleDateTitle">日付のスケジュール</h3>
              <p id="scheduleDateSubtitle">30分刻みでその日の予定を表示します</p>
            </div>
            <h4>未配置タスク一覧</h4>
            <p class="day-schedule-sidebar-subtitle">タスクを右の時間枠へドラッグしてください。左側へ戻すと期日に応じて自動分類されます。</p>
            <div id="unscheduledTaskFilters" class="unscheduled-task-filters"></div>
            <div id="unscheduledTaskList" class="unscheduled-task-list"></div>
            <div class="overdue-task-section">
              <button type="button" id="overdueTaskToggle" class="overdue-task-toggle" aria-expanded="false" aria-controls="overdueTaskContent">
                <span>期日超過タスク一覧</span>
                <span class="overdue-task-toggle-summary">
                  <span id="overdueTaskCount">0件</span>
                  <span class="overdue-task-toggle-icon" aria-hidden="true">⌄</span>
                </span>
              </button>
              <div id="overdueTaskContent" class="overdue-task-content hidden">
                <p class="day-schedule-sidebar-subtitle">選択日より前が期日のタスクです（古い期日から表示）。</p>
                <div id="overdueTaskFilters" class="unscheduled-task-filters"></div>
                <div id="overdueTaskList" class="unscheduled-task-list"></div>
              </div>
            </div>
          </div>
          <div class="day-schedule-main">
            <div id="scheduleTimeline" class="schedule-timeline"></div>
          </div>
        </div>
      </div>
    </div>

    <section class="auto-schedule-card" aria-labelledby="autoScheduleTitle">
      <div class="auto-schedule-heading">
        <div>
          <h2 id="autoScheduleTitle">自動スケジュール</h2>
          <p>タスク設定とユーザー設定から、期日までの空き時間を探します。</p>
        </div>
      </div>
      <%
        const autoScheduleCandidates = todos.filter(todo =>
          !todo.isCompleted &&
          todo.dueDate &&
          todo.estimatedMinutes &&
          todo.remainingEstimatedMinutes > 0 &&
          (!todo.isSplittable || todo.splitMinutes)
        );
      %>
      <div class="auto-schedule-controls">
        <label for="autoScheduleTodoSelect">対象タスク</label>
        <select id="autoScheduleTodoSelect" class="auto-schedule-select" onchange="resetAutoSchedulePreview()">
          <option value="">対象タスクを選択</option>
          <% autoScheduleCandidates.forEach(todo => { %>
            <option value="<%= todo.id %>"><%= todo.title %>　⏱ 見積 <%= formatEstimatedHours(todo.estimatedMinutes) %>時間<% if (todo.isSplittable && todo.splitMinutes) { %> / <%= formatEstimatedHours(todo.splitMinutes) %>時間ずつ<% } %>・残り<%= formatEstimatedHours(todo.remainingEstimatedMinutes) %>時間</option>
          <% }) %>
        </select>
        <button type="button" id="autoSchedulePreviewBtn" class="auto-schedule-run-btn" onclick="executeAutoSchedulePreview()" <%= autoScheduleCandidates.length === 0 ? 'disabled' : '' %>>自動配置を実行</button>
      </div>
      <p id="autoScheduleEmpty" class="auto-schedule-empty <%= autoScheduleCandidates.length === 0 ? '' : 'hidden' %>">見積時間と期日が設定された未完了タスクがありません。</p>
      <div id="autoScheduleMessage" class="auto-schedule-message hidden" role="status" aria-live="polite"></div>
      <div id="autoSchedulePreview" class="auto-schedule-preview hidden">
        <h3>次の内容で自動配置します</h3>
        <ul id="autoSchedulePreviewList"></ul>
        <div class="auto-schedule-preview-actions">
          <button type="button" class="auto-schedule-confirm-btn" onclick="confirmAutoSchedule()">確定</button>
          <button type="button" class="auto-schedule-cancel-btn" onclick="cancelAutoSchedulePreview()">キャンセル</button>
        </div>
      </div>
    </section>
  </div>

  <h2>タスクを追加する</h2>
  <div id="validationErrorBox" class="client-error-msg <%= (safeErrorType === 'emptyTitle' || safeErrorType === 'duplicate' || safeErrorType === 'invalidAutoPlacement' || safeErrorType === 'splitExceedsDailyLimit' || safeErrorType === 'splitExceedsEstimate') && safeErrorMessage ? '' : 'hidden' %>">
    <span>⚠️</span>
    <span><%= safeErrorMessage || 'タスク名を入力してくださいな。' %></span>
  </div>

  <button type="button" class="form-toggle-btn" id="toggleModeBtn" onclick="toggleInputMode()">💬 メモ風に自由に入力する</button>

  <div class="input-box">
    <form id="todoForm" action="/todos" method="POST">
      <input type="hidden" name="view" id="viewInput" value="<%= initialView || 'today' %>">
      <div id="simpleInputMode" class="<%= (safeFormValues && safeFormValues.currentMode === 'simple') ? '' : 'hidden' %>">
        <textarea name="titleSimple" id="titleSimple" class="big-textarea" placeholder="例：来週金曜日までに研究発表の資料を早急に作る。このタスクは研究の分類に入れてください"><%= safeFormValues && safeFormValues.titleSimple ? safeFormValues.titleSimple : '' %></textarea>
        <button type="button" id="analyzeSimpleTaskBtn" class="task-analysis-btn">文章を解析して詳細入力へ反映</button>
      </div>

      <div id="detailInputMode" class="<%= (safeFormValues && safeFormValues.currentMode === 'simple') ? 'hidden' : '' %>">
        <div class="form-group">
          <label>タスク名</label>
          <input type="text" name="title" id="titleDetail" class="standard-input" placeholder="新しいタスクを入力してください" value="<%= safeFormValues && safeFormValues.title ? safeFormValues.title : '' %>">
        </div>
        <div style="display: flex; gap: 10px;">
          <div class="form-group" style="flex: 1;">
            <label>期日</label>
            <input type="date" name="dueDate" id="dueDateField" class="standard-input" value="<%= safeFormValues && safeFormValues.dueDate ? safeFormValues.dueDate : '' %>">
          </div>
          <div class="form-group" style="flex: 1;">
            <label>重要度</label>
            <select name="priority" id="prioritySelect" class="standard-input">
              <option value="高" <%= safeFormValues && safeFormValues.priority === '高' ? 'selected' : '' %>>🚨 高</option>
              <option value="中" <%= (!safeFormValues || safeFormValues.priority === '中' || !safeFormValues.priority) ? 'selected' : '' %>>🟡 中</option>
              <option value="低" <%= safeFormValues && safeFormValues.priority === '低' ? 'selected' : '' %>>🟢 低</option>
            </select>
          </div>
        </div>
        <div class="auto-placement-form-grid">
          <div class="form-group">
            <label>見積時間</label>
            <span class="duration-input standard-duration-input">
              <input type="number" name="estimatedHours" id="estimatedHoursField" min="0.25" step="0.25" class="standard-input" placeholder="未設定" value="<%= safeFormValues && safeFormValues.estimatedHours ? safeFormValues.estimatedHours : '' %>">
              <span>時間</span>
            </span>
          </div>
          <div class="form-group">
            <label>分割できるか</label>
            <select name="isSplittable" id="isSplittableField" class="standard-input" onchange="updateSplitEstimateVisibility('isSplittableField', 'splitHoursGroup', 'splitHoursField', 'dailyLimitHoursGroup', 'dailyLimitHoursField')">
              <option value="false" <%= !safeFormValues || safeFormValues.isSplittable !== 'true' ? 'selected' : '' %>>分割できない</option>
              <option value="true" <%= safeFormValues && safeFormValues.isSplittable === 'true' ? 'selected' : '' %>>分割できる</option>
            </select>
          </div>
          <div id="splitHoursGroup" class="form-group <%= safeFormValues && safeFormValues.isSplittable === 'true' ? '' : 'hidden' %>">
            <label>1回あたりの見積時間</label>
            <span class="duration-input standard-duration-input">
              <input type="number" name="splitHours" id="splitHoursField" min="0.25" step="0.25" class="standard-input" placeholder="例：1" value="<%= safeFormValues && safeFormValues.splitHours !== undefined ? safeFormValues.splitHours : '1' %>" <%= safeFormValues && safeFormValues.isSplittable === 'true' ? 'required' : 'disabled' %>>
              <span>時間</span>
            </span>
          </div>
          <div id="dailyLimitHoursGroup" class="form-group <%= safeFormValues && safeFormValues.isSplittable === 'true' ? '' : 'hidden' %>">
            <label>1日の実施時間上限</label>
            <span class="duration-input standard-duration-input">
              <input type="number" name="dailyLimitHours" id="dailyLimitHoursField" min="0.25" step="0.25" class="standard-input" placeholder="例：2" value="<%= safeFormValues && safeFormValues.dailyLimitHours !== undefined ? safeFormValues.dailyLimitHours : '2' %>" <%= safeFormValues && safeFormValues.isSplittable === 'true' ? 'required' : 'disabled' %>>
              <span>時間</span>
            </span>
          </div>
        </div>
        <div class="form-group">
          <label>分類（カテゴリ）</label>
          <select name="categoryId" id="categorySelect" class="standard-input" onchange="handleCategoryChange()">
            <option value="指定なし" <%= safeFormValues && safeFormValues.categoryId === '指定なし' ? 'selected' : '' %>>指定なし</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>" <%= safeFormValues && String(safeFormValues.categoryId) === String(cat.id) ? 'selected' : '' %>><%= cat.name %></option>
            <% }) %>
            <option value="__NEW__" <%= safeFormValues && safeFormValues.categoryId === '__NEW__' ? 'selected' : '' %>>（＋ 新しい分類を追加）</option>
          </select>
          <span id="newCategoryWrapper" class="hidden" style="display: block; margin-top: 5px;">
            <input type="text" name="newCategory" id="newCategoryInput" class="standard-input" placeholder="新しい分類名を入力" value="<%= safeFormValues && safeFormValues.newCategory ? safeFormValues.newCategory : '' %>">
          </span>
        </div>
      </div>

      <div id="taskAnalysisMessage" class="task-analysis-message hidden" role="status"></div>

      <div class="form-actions">
        <button type="submit" class="submit-btn">タスクを追加</button>
        <button type="button" class="reset-btn" onclick="resetWholeForm()">🔄 全てリセット</button>
      </div>
      <button type="button" id="deleteCategoryBtn" class="hidden" onclick="deleteSelectedCategory()" style="margin-top: 10px; color: #e53e3e; background: none; border: 1px solid #e53e3e; padding: 4px 8px; border-radius: 4px; cursor: pointer; width: 100%;">❌ この分類自体を非表示にする</button>
    </form>
  </div>

  <script>
    window.initialView = "<%= initialView || 'today' %>";
  </script>
  <script src="/js/task-text-parser.js"></script>
  <script src="/js/app.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const calendarEl = document.getElementById('calendar');
      
      window.scheduleTasks = <%- JSON.stringify(todos.map(todo => ({
        id: todo.id,
        title: todo.title,
        dueDate: todo.dueDate ? todo.dueDate.toISOString() : null,
        priority: todo.priority,
        isCompleted: todo.isCompleted,
        estimatedMinutes: todo.estimatedMinutes,
        isSplittable: todo.isSplittable,
        splitMinutes: todo.splitMinutes,
        schedules: (todo.schedules || []).map(schedule => ({
          id: schedule.id,
          scheduledStart: schedule.scheduledStart.toISOString(),
          scheduledEnd: schedule.scheduledEnd.toISOString()
        })),
        categoryName: categories.find(c => c.id === todo.categoryId)?.name || '分類なし'
      }))) %>;

      const calendarEvents = [
        <% todos.forEach(todo => { %>
          <% if (todo.dueDate) { 
               const d = new Date(todo.dueDate);
               const dateStr = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
               
               let color = '#a0aec0';
               if (!todo.isCompleted) {
                 if (todo.priority === '高') color = '#e53e3e';
                 else if (todo.priority === '中') color = '#dd6b20';
                 else if (todo.priority === '低') color = '#38a169';
               }
               
               const catObj = categories.find(c => c.id === todo.categoryId);
               const catName = catObj ? catObj.name : '分類なし';
          %>
            {
              id: '<%= todo.id %>',
              title: '<%= todo.title.replace(/'/g, "\\'") %>',
              start: '<%= dateStr %>',
              backgroundColor: '<%= color %>',
              extendedProps: {
                priority: '<%= todo.priority %>',
                isCompleted: <%= todo.isCompleted %>,
                categoryName: '<%= catName.replace(/'/g, "\\'") %>'
              }
            },
          <% } %>
        <% }) %>
      ];

      calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        initialDate: '2026-07-08',
        locale: 'ja',
        height: 'auto',
        headerToolbar: {
          left: 'prev,next today',
          center: 'title',
          right: 'dayGridMonth'
        },
        buttonText: { today: '今日', month: '月' },
        events: calendarEvents,
        datesSet: function() {
          requestAnimationFrame(renderPlacementMarkers);
        },
        dateClick: function(info) {
          openDaySchedule(info.dateStr);
        },
        eventClick: function(info) {
          openDaySchedule(info.event.startStr.slice(0, 10));
        }
      });

      calendar.render();
      initializePlacementTaskInspector();
      renderPlacementMarkers();
    });
  </script>
</body>
</html>
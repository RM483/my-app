<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>進化系タスク管理アプリ</title>
  
  <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
  
  <link href="/css/style.css" rel="stylesheet" />
</head>
<body>
  <h1>タスク管理システム</h1>

  <div class="view-switcher">
    <button type="button" id="listViewBtn" class="switch-btn active" onclick="switchView('list')">📋 リスト表示</button>
    <button type="button" id="calendarViewBtn" class="switch-btn" onclick="switchView('calendar')">📅 カレンダー表示</button>
  </div>

  <div id="listViewArea">
    <div class="search-container">
      <input type="text" id="taskSearchInput" class="search-input" placeholder="🔍 タスク名でキーワード検索... (入力すると一瞬で絞り込みます)" oninput="applyFilters()">
    </div>
    
    <% if (categories.length > 0 || todos.some(t => !t.categoryId)) { %>
      <div class="category-filter-container">
        <button type="button" class="filter-btn master-btn" id="masterFilterBtn" onclick="toggleMasterFilter()">
          <span class="icon">📄</span> すべて表示
        </button>
        <% categories.forEach(cat => { %>
          <button type="button" class="filter-btn category-btn" data-category-id="<%= cat.id %>" onclick="toggleCategoryFilter(this)">
            <span class="check-mark">✓</span> <%= cat.name %>
          </button>
        <% }) %>
        <button type="button" class="filter-btn category-btn" data-category-id="none" onclick="toggleCategoryFilter(this)">
          <span class="check-mark">✓</span> [分類なし]
        </button>
      </div>
    <% } %>

    <div class="todo-container">
      <% if (todos.length === 0) { %>
        <p style="color: gray; text-align: center;">タスクはまだありませんぞよ。</p>
      <% } %>
      <ul style="list-style: none; padding: 0; margin: 0;">
        <% todos.forEach(todo => { %>
          <% 
            let alertClass = "";
            let dateTextClass = "";
            let prefixText = "";
            let dateString = "";

            if (todo.dueDate) {
              const d = new Date(todo.dueDate);
              dateString = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
              
              const today = new Date('2026-07-08');
              today.setHours(0,0,0,0);
              const taskDate = new Date(todo.dueDate);
              taskDate.setHours(0,0,0,0);

              if (!todo.isCompleted) {
                if (taskDate.getTime() === today.getTime()) {
                  alertClass = "alert-today";
                  dateTextClass = "date-text-today";
                  prefixText = "📅 今日";
                } else if (taskDate.getTime() < today.getTime()) {
                  alertClass = "alert-overdue";
                  dateTextClass = "date-text-overdue";
                  prefixText = "🚨 期限切れ";
                }
              }
            }
          %>
          <li class="todo-item <%= alertClass %>" data-cat="<%= todo.categoryId ? todo.categoryId : 'none' %>" data-title="<%= todo.title.toLowerCase() %>">
            <form action="/todos/<%= todo.id %>/toggle" method="POST" style="display: flex; align-items: center;">
              <button type="submit" class="toggle-check-btn <%= todo.isCompleted ? 'completed' : '' %>">✓</button>
            </form>

            <form action="/todos/<%= todo.id %>/update" method="POST" style="display: flex; align-items: center;">
              <select name="priority" class="inline-select <%= todo.isCompleted ? 'completed' : '' %>" onchange="this.form.submit()">
                <option value="高" <%= todo.priority === '高' ? 'selected' : '' %>>🚨 高</option>
                <option value="中" <%= todo.priority === '中' ? 'selected' : '' %>>🟡 中</option>
                <option value="低" <%= todo.priority === '低' ? 'selected' : '' %>>🟢 低</option>
              </select>
            </form>

            <div style="display: flex; align-items: center;">
              <form action="/todos/<%= todo.id %>/category" method="POST" id="catForm-<%= todo.id %>" style="display: flex; align-items: center;">
                <select name="categoryId" class="inline-select <%= todo.isCompleted ? 'completed' : '' %>" onchange="handleInlineCategoryChange(this, '<%= todo.id %>')">
                  <option value="指定なし" <%= !todo.categoryId ? 'selected' : '' %>>[分類なし ▾]</option>
                  <% categories.forEach(cat => { %>
                    <option value="<%= cat.id %>" <%= todo.categoryId === cat.id ? 'selected' : '' %>>[<%= cat.name %> ▾]</option>
                  <% }) %>
                  <option value="__INLINE_NEW__">➕ （新しい分類を追加）</option>
                </select>
              </form>
              <form action="/todos/<%= todo.id %>/category/create" method="POST" id="newCatForm-<%= todo.id %>" class="hidden" style="display: flex; align-items: center;">
                <input type="text" name="newCategoryName" class="inline-cat-input" placeholder="分類名を入力..." onblur="cancelInlineCategory('<%= todo.id %>')">
              </form>
            </div>

            <form action="/todos/<%= todo.id %>/update" method="POST" style="flex-grow: 1; display: flex; align-items: center;">
              <input type="text" name="title" class="inline-input-title <%= todo.isCompleted ? 'completed' : '' %>" value="<%= todo.title %>" onchange="this.form.submit()" <%= todo.isCompleted ? 'disabled' : '' %>>
            </form>

            <form action="/todos/<%= todo.id %>/update" method="POST" style="display: flex; align-items: center; gap: 4px;">
              <% if (prefixText) { %>
                <span class="<%= dateTextClass %>" style="font-size: 0.8em; white-space: nowrap;"><%= prefixText %></span>
              <% } %>
              <input type="date" name="dueDate" class="inline-date <%= todo.isCompleted ? 'completed' : '' %>" value="<%= dateString %>" onchange="this.form.submit()">
            </form>

            <form action="/todos/<%= todo.id %>/delete" method="POST" style="display: flex; align-items: center; margin-left: 4px;">
              <button type="submit" style="color: white; background-color: #e53e3e; border: none; padding: 4px 8px; border-radius: 4px; cursor: pointer; font-size: 0.85em;">削除</button>
            </form>
          </li>
        <% }) %>
      </ul>
    </div>
  </div>

  <div id="calendarViewArea" class="hidden">
    <div class="calendar-container">
      <div id="calendar"></div>
    </div>
  </div>

  <h2>タスクを追加する</h2>
  <div id="validationErrorBox" class="client-error-msg hidden">⚠️ タスク名を入力してくださいな。</div>

  <button type="button" class="form-toggle-btn" id="toggleModeBtn" onclick="toggleInputMode()">💬 メモ風に自由に入力する</button>

  <div class="input-box">
    <form id="todoForm" action="/todos" method="POST">
      <div id="simpleInputMode" class="hidden">
        <textarea name="titleSimple" id="titleSimple" class="big-textarea" placeholder="ここにタスクを自由に書きなぐってください"></textarea>
      </div>

      <div id="detailInputMode">
        <div class="form-group">
          <label>タスク名</label>
          <input type="text" name="title" id="titleDetail" class="standard-input" placeholder="新しいタスクを入力してください">
        </div>
        <div style="display: flex; gap: 10px;">
          <div class="form-group" style="flex: 1;">
            <label>期日</label>
            <input type="date" name="dueDate" id="dueDateField" class="standard-input">
          </div>
          <div class="form-group" style="flex: 1;">
            <label>重要度</label>
            <select name="priority" id="prioritySelect" class="standard-input">
              <option value="高">🚨 高</option>
              <option value="中" selected>🟡 中</option>
              <option value="低">🟢 低</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>分類（カテゴリ）</label>
          <select name="categoryId" id="categorySelect" class="standard-input" onchange="handleCategoryChange()">
            <option value="指定なし">指定なし</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }) %>
            <option value="__NEW__">（＋ 新しい分類を追加）</option>
          </select>
          <span id="newCategoryWrapper" class="hidden" style="display: block; margin-top: 5px;">
            <input type="text" name="newCategory" id="newCategoryInput" class="standard-input" placeholder="新しい分類名を入力">
          </span>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="submit-btn">タスクを追加</button>
        <button type="button" class="reset-btn" onclick="resetWholeForm()">🔄 全てリセット</button>
      </div>
      <button type="button" id="deleteCategoryBtn" class="hidden" onclick="deleteSelectedCategory()" style="margin-top: 10px; color: #e53e3e; background: none; border: 1px solid #e53e3e; padding: 4px 8px; border-radius: 4px; cursor: pointer; width: 100%;">❌ この分類自体を非表示にする</button>
    </form>
  </div>

  <script src="/js/app.js"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const calendarEl = document.getElementById('calendar');
      
      const calendarEvents = [
        <% todos.forEach(todo => { %>
          <% if (todo.dueDate) { 
               const d = new Date(todo.dueDate);
               const dateStr = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
               
               let color = '#a0aec0';
               if (!todo.isCompleted) {
                 if (todo.priority === '高') color = '#e53e3e';
                 else if (todo.priority === '中') color = '#dd6b20';
                 else if (todo.priority === '低') color = '#38a169';
               }
               
               const catObj = categories.find(c => c.id === todo.categoryId);
               const catName = catObj ? catObj.name : '分類なし';
          %>
            {
              id: '<%= todo.id %>',
              title: '<%= todo.title.replace(/'/g, "\\'") %>',
              start: '<%= dateStr %>',
              backgroundColor: '<%= color %>',
              extendedProps: {
                priority: '<%= todo.priority %>',
                isCompleted: <%= todo.isCompleted %>,
                categoryName: '<%= catName.replace(/'/g, "\\'") %>'
              }
            },
          <% } %>
        <% }) %>
      ];

      calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        initialDate: '2026-07-08',
        locale: 'ja',
        headerToolbar: {
          left: 'prev,next today',
          center: 'title',
          right: 'dayGridMonth'
        },
        buttonText: { today: '今日', month: '月' },
        events: calendarEvents
      });

      calendar.render();
    });
  </script>
</body>
</html>